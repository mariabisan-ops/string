#include <stdio.h>
#include <string.h>

int main (){
    char nome[50];
    int cont=0;
    printf ("Nome: ");
    fgets (nome, sizeof(nome), stdin);
    nome[strlen(nome)-1] = '\0';

    for (int i =0; i<strlen(nome); i++){
        if (nome[i]!= ' '){
            cont++;
        }
    }

    printf ("número de letras: %d", cont);

}
