#include <stdio.h>
#include <string.h>

int main (){
    char nome[50];
    int cont=0;
    printf ("nome:");
    fgets (nome, sizeof (nome), stdin);
    nome [strlen (nome)-1] = '\0';
    printf ("%s", nome);

    while (nome[cont]!='\0'){
        cont++;
    }

    printf ("\nnumero de caracteres: %d", cont);
}
